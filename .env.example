APPWRITE_STUDENT_PAGES_COLLECTION_ID=YOUR_STUDENT_PAGES_COLLECTION_ID
APPWRITE_STUDENTS_TEAM_ID=YOUR_STUDENTS_TEAM_ID
APPWRITE_ALLOWED_DOMAIN=students.example.edu
APPWRITE_ADMIN_EMAILS=admin@example.edu
